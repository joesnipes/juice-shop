# OWASP Juice Shop — example environment variables.
# Copy to `.env` (which IS git-ignored) and populate with REAL values.
# NEVER commit `.env`.

# ---- JWT signing ----
# Path to a freshly generated RSA-2048 (or Ed25519) PRIVATE key. The
# leaked key that was previously committed to lib/insecurity.ts must be
# considered fully compromised — generate a NEW pair on first deploy.
#
# Generate locally:
#   openssl genrsa -out encryptionkeys/jwt.key 2048
#   openssl rsa -in encryptionkeys/jwt.key -pubout -out encryptionkeys/jwt.pub
#
# Both files are now .gitignore'd (see .gitignore).
JWT_PRIVATE_KEY_PATH=encryptionkeys/jwt.key
JWT_PUBLIC_KEY_PATH=encryptionkeys/jwt.pub
# Alternative: supply PEM directly via environment (preferred in cloud /
# secret-manager deployments). Whichever is set wins over the path.
# JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ---- Security-answer HMAC ----
# Random 256-bit secret used to HMAC security-question answers and the
# deluxe-membership token. Generate with:
#   openssl rand -hex 32
SECURITY_ANSWER_HMAC_SECRET=replace-with-openssl-rand-hex-32

# ---- Web3 / Alchemy ----
# Sepolia testnet Alchemy WebSocket key. The previously-committed key was
# leaked publicly (JS-AUDIT-030) and MUST be rotated before redeploy.
ALCHEMY_WSS_URL=wss://eth-sepolia.g.alchemy.com/v2/REPLACE_WITH_FRESH_KEY

# ---- NFT challenge mnemonic ----
# Was a hard-coded BIP-39 mnemonic in routes/checkKeys.ts (JS-AUDIT-040).
# In a real deployment generate one with `npx bip39` or similar and store
# only the mnemonic here — never commit.
NFT_CHALLENGE_MNEMONIC=replace-with-newly-generated-bip39-mnemonic

# ---- Misc ----
NODE_ENV=development
BASE_PATH=
