            {
              "id": "CANON-SAST-014",
              "name": "CANON-SAST-014",
              "shortDescription": {
                "text": "Open redirect allowlist can be bypassed with substring match"
              },
              "fullDescription": {
                "text": "The public /redirect route redirects to attacker-controlled to= values if they contain any allowlisted URL as a substring. An attacker can craft a malicious URL that embeds an allowed URL in query/path/userinfo and use the trusted domain as a phishing or token-leak primitive."
              },
              "help": {
                "text": "Remediation: Parse URLs with the URL API and compare exact scheme, hostname, port, and path against an allowlist. Prefer server-side redirect IDs instead of arbitrary URLs."
              },
              "properties": {
