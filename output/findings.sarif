            {
              "id": "CANON-SAST-012",
              "name": "CANON-SAST-012",
              "shortDescription": {
                "text": "Weak unsalted MD5 password hashing"
              },
              "fullDescription": {
                "text": "Passwords are stored as fast unsalted MD5 hashes. Confirmed SQL injection and full database access paths make offline cracking practical and fast, enabling account takeover beyond the initial exploit."
              },
              "help": {
                "text": "Remediation: Migrate passwords to Argon2id or bcrypt with per-password salts and a work factor, implement hash versioning, and rehash on next login or forced reset."
              },
              "properties": {
