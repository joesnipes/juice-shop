                  "CWE-94"
                ],
                "owasp": [
                  "A03:2021-Injection"
                ],
                "triage": "confirmed"
              }
            },
            {
              "id": "JS-AUDIT-020",
              "name": "Mass update via multi:true with body-controlled filter (review forgery)",
              "shortDescription": {
                "text": "Mass update via multi:true with body-controlled filter (review forgery)"
              },
              "fullDescription": {
                "text": "The filter `_id` is whatever the user sends — including operators like `{$ne: null}` which match every document. With multi:true a single PATCH overwrites every review in the database. No ownership check (review.author == user.email) is performed."
              },
              "help": {
                "text": "Recommended fix: Coerce req.body.id to a string and add `{ author: user.data.email }` to the filter. Drop multi:true.",
                "markdown": "## Mass update via multi:true with body-controlled filter (review forgery)\n\n**CWE:** CWE-639\n\n**OWASP:** A01:2021-Broken Access Control\n\n### Exploitation\n\nThe filter `_id` is whatever the user sends — including operators like `{$ne: null}` which match every document. With multi:true a single PATCH overwrites every review in the database. No ownership check (review.author == user.email) is performed.\n\n### Recommended Fix\n\nCoerce req.body.id to a string and add `{ author: user.data.email }` to the filter. Drop multi:true."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "security-severity": "7.7",
                "tags": [
                  "idor",
                  "nosql_injection",
                  "tier2"
                ],
                "precision": "high",
                "cwe": [
                  "CWE-639"
                ],
                "owasp": [
                  "A01:2021-Broken Access Control"
                ],
                "triage": "confirmed"
              }
            },
            {
              "id": "JS-AUDIT-021",
              "name": "IDOR: body-controlled UserId determines wallet balance reads/writes",
              "shortDescription": {
                "text": "IDOR: body-controlled UserId determines wallet balance reads/writes"
              },
              "fullDescription": {
                "text": "appendUserId() writes req.body.UserId, but body fields submitted by the client overwrite/merge. By POSTing {UserId: <victimId>, balance: 1000000} the attacker drains/credits arbitrary wallets. The same body field also controls the SELECT and the card ownership check."
              },
              "help": {
                "text": "Recommended fix: Derive UserId server-side from the JWT *after* clearing any client-supplied value. Reject requests that contain UserId in body.",
                "markdown": "## IDOR: body-controlled UserId determines wallet balance reads/writes\n\n**CWE:** CWE-639\n\n**OWASP:** A01:2021-Broken Access Control\n\n### Exploitation\n\nappendUserId() writes req.body.UserId, but body fields submitted by the client overwrite/merge. By POSTing {UserId: <victimId>, balance: 1000000} the attacker drains/credits arbitrary wallets. The same body field also controls the SELECT and the card ownership check.\n\n### Recommended Fix\n\nDerive UserId server-side from the JWT *after* clearing any client-supplied value. Reject requests that contain UserId in body."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "security-severity": "8.1",
                "tags": [
                  "idor",
                  "tier2"
                ],
                "precision": "high",
                "cwe": [
                  "CWE-639"
                ],
                "owasp": [
                  "A01:2021-Broken Access Control"
                ],
                "triage": "confirmed"
              }
            },
            {
              "id": "JS-AUDIT-022",
              "name": "IDOR in /rest/user/data-export via body-supplied UserId",
              "shortDescription": {
                "text": "IDOR in /rest/user/data-export via body-supplied UserId"
              },
              "fullDescription": {
                "text": "MemoryModel query uses req.body.UserId (mass-assigned by appendUserId() but client-overridable). Attacker harvests other users' memories. Orders/reviews are queried by the logged-in email (better) but the memories leak is sufficient for a privacy breach."
              },
              "help": {
                "text": "Recommended fix: Use loggedInUser.data.id; ignore body.UserId.",
                "markdown": "## IDOR in /rest/user/data-export via body-supplied UserId\n\n**CWE:** CWE-639\n\n**OWASP:** A01:2021-Broken Access Control\n\n### Exploitation\n\nMemoryModel query uses req.body.UserId (mass-assigned by appendUserId() but client-overridable). Attacker harvests other users' memories. Orders/reviews are queried by the logged-in email (better) but the memories leak is sufficient for a privacy breach.\n\n### Recommended Fix\n\nUse loggedInUser.data.id; ignore body.UserId."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "security-severity": "7.7",
                "tags": [
                  "idor",
                  "info_disclosure",
                  "tier2"
                ],
                "precision": "high",
                "cwe": [
                  "CWE-639"
                ],
                "owasp": [
                  "A01:2021-Broken Access Control"
                ],
                "triage": "confirmed"
              }
            },
            {
              "id": "JS-AUDIT-023",
              "name": "IDOR on /api/Addresss/:id via body UserId",
              "shortDescription": {
                "text": "IDOR on /api/Addresss/:id via body UserId"
              },
              "fullDescription": {
                "text": "Same pattern: appendUserId puts UserId in body but the body can be tampered with. Read/delete arbitrary addresses."
