{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Barrys Special AI Vuln Audit",
          "informationUri": "https://github.com/OWASP/juice-shop",
          "version": "1.0.0",
          "rules": [
            {
              "id": "CANON-SAST-001",
              "name": "CANON-SAST-001",
              "shortDescription": {
                "text": "Authentication SQL injection permits login bypass"
              },
              "fullDescription": {
                "text": "The public POST /rest/user/login route passes attacker-controlled email directly into a raw SQL template string. A production attacker can alter the WHERE clause to authenticate as another account, including privileged users, before JWT issuance."
              },
              "help": {
                "text": "Remediation: Replace raw string interpolation with parameterized Sequelize replacements/bind parameters, validate email format before query execution, and add regression tests for SQL metacharacters."
              },
              "properties": {
                "tags": [
                  "security",
                  "triage:confirmed",
                  "type:SAST",
                  "severity:critical",
                  "CWE-89",
                  "A03:2021-Injection",
                  "API8:2023-Security Misconfiguration"
                ],
                "cwe": [
                  "CWE-89"
                ],
                "owasp": [
                  "A03:2021-Injection",
                  "API8:2023-Security Misconfiguration"
                ],
                "security-severity": "9.8",
                "precision": "high"
              }
            },
            {
              "id": "CANON-SAST-002",
              "name": "CANON-SAST-002",
              "shortDescription": {
                "text": "Product search SQL injection leaks database data"
              },
              "fullDescription": {
                "text": "The public GET /rest/products/search endpoint places req.query.q into a SQL LIKE clause. The 200-character truncation does not neutralize SQL syntax; UNION payloads can exfiltrate users, password hashes, schema, and other SQLite content."
              },
              "help": {
                "text": "Remediation: Use parameterized LIKE queries with bound replacements, escape wildcard characters intentionally, and enforce query allowlists/length limits after parameterization."
              },
              "properties": {
                "tags": [
                  "security",
                  "triage:confirmed",
                  "type:SAST",
                  "severity:critical",
                  "CWE-89",
                  "A03:2021-Injection",
                  "API8:2023-Security Misconfiguration"
                ],
                "cwe": [
                  "CWE-89"
                ],
                "owasp": [
                  "A03:2021-Injection",
                  "API8:2023-Security Misconfiguration"
                ],
                "security-severity": "9.1",
                "precision": "high"
              }
            },
            {
              "id": "CANON-HYBRID-003",
              "name": "CANON-HYBRID-003",
              "shortDescription": {
                "text": "Hardcoded JWT private key and vulnerable JWT stack enable token forgery"
              },
              "fullDescription": {
                "text": "The signing private key is embedded in source and used to sign all authentication tokens. Any party with repository/container access can mint arbitrary role claims; public routes then trust decoded token roles for accounting/admin-like actions. SCA confirms very old direct dependencies jsonwebtoken 0.4.0 and express-jwt 0.1.3 are in use, increasing verification bypass risk, but the hardcoded key alone is sufficient for exploitation."
              },
              "help": {
                "text": "Remediation: Move signing keys to a KMS/secret manager, rotate keys, remove source-controlled keys, pin accepted algorithms in jwt.verify/express-jwt, upgrade jsonwebtoken and express-jwt to maintained versions, and authorize privileged actions from server-side policy not self-contained mutable claims."
              },
              "properties": {
                "tags": [
                  "security",
                  "triage:confirmed",
                  "type:SAST/SCA",
                  "severity:critical",
                  "CWE-321",
                  "CWE-347",
                  "CWE-798",
                  "A02:2021-Cryptographic Failures",
                  "A07:2021-Identification and Authentication Failures"
                ],
                "cwe": [
                  "CWE-321",
                  "CWE-347",
                  "CWE-798"
                ],
                "owasp": [
                  "A02:2021-Cryptographic Failures",
                  "A07:2021-Identification and Authentication Failures"
                ],
                "security-severity": "9.8",
                "precision": "high"
              }
            },
            {
              "id": "CANON-SAST-004",
              "name": "CANON-SAST-004",
              "shortDescription": {
                "text": "Broken object-level authorization exposes and checks out other users' baskets"
              },
              "fullDescription": {
                "text": "Authenticated users can supply arbitrary basket IDs. Middleware appends the caller's UserId but these queries do not constrain by UserId/bid, so a user can read another basket and submit checkout for it, causing item removal, order creation, inventory changes, and wallet effects."
              },
              "help": {
                "text": "Remediation: For all basket operations query by both basket id and authenticated UserId/bid. Return 404/403 for mismatches and add customer A/customer B authorization tests."
              },
              "properties": {
                "tags": [
                  "security",
                  "triage:confirmed",
                  "type:SAST",
                  "severity:high",
                  "CWE-639",
                  "CWE-862",
                  "A01:2021-Broken Access Control",
                  "API1:2023-Broken Object Property Level Authorization"
                ],
                "cwe": [
                  "CWE-639",
                  "CWE-862"
                ],
                "owasp": [
                  "A01:2021-Broken Access Control",
                  "API1:2023-Broken Object Property Level Authorization"
                ],
                "security-severity": "8.8",
                "precision": "high"
              }
            },
            {
              "id": "CANON-SAST-005",
              "name": "CANON-SAST-005",
              "shortDescription": {
                "text": "Server-side request forgery through profile image URL fetch"
              },
              "fullDescription": {
                "text": "An authenticated user controls imageUrl, and the server fetches it without scheme, host, DNS, private-IP, metadata-IP, timeout, redirect, content-type, or byte-limit controls. This can reach internal services and write attacker-controlled responses into a public uploads directory."
              },
              "help": {
                "text": "Remediation: Require HTTPS and an allowlist or dedicated media proxy; block private, loopback, link-local and metadata ranges after DNS resolution; disable unsafe redirects; set strict timeouts and max response size; validate MIME by content."
              },
              "properties": {
                "tags": [
                  "security",
                  "triage:confirmed",
                  "type:SAST",
                  "severity:high",
                  "CWE-918",
                  "A10:2021-Server-Side Request Forgery",
                  "API7:2023-Server Side Request Forgery"
                ],
                "cwe": [
                  "CWE-918"
                ],
                "owasp": [
                  "A10:2021-Server-Side Request Forgery",
                  "API7:2023-Server Side Request Forgery"
                ],
                "security-severity": "8.6",
                "precision": "high"
              }
            },
            {
              "id": "CANON-HYBRID-006",
              "name": "CANON-HYBRID-006",
              "shortDescription": {
                "text": "B2B order endpoint evaluates attacker-supplied code with vulnerable notevil sandbox"
              },
              "fullDescription": {
                "text": "Authenticated callers of POST /b2b/v2/orders can provide orderLinesData that is evaluated as code. The notevil package is explicitly flagged for sandbox escape (GHSA-8g4m-cjm2-96wq) and this code wraps it in a Node vm context, which is not a security boundary. Successful exploitation can execute code in the application process."
              },
              "help": {
                "text": "Remediation: Remove evaluation entirely. Parse a declarative JSON schema for order lines, validate with a schema validator, and run complex imports in an isolated worker/container without access to secrets or filesystem."
              },
              "properties": {
                "tags": [
                  "security",
                  "triage:confirmed",
                  "type:SAST/SCA",
                  "severity:critical",
                  "CWE-94",
                  "CWE-913",
                  "A03:2021-Injection",
                  "API8:2023-Security Misconfiguration"
                ],
                "cwe": [
                  "CWE-94",
                  "CWE-913"
                ],
                "owasp": [
                  "A03:2021-Injection",
                  "API8:2023-Security Misconfiguration"
                ],
                "security-severity": "9.0",
                "precision": "high"
              }
            },
            {
              "id": "CANON-SAST-007",
              "name": "CANON-SAST-007",
              "shortDescription": {
                "text": "XML upload enables XXE and response disclosure"
              },
              "fullDescription": {
                "text": "The unauthenticated /file-upload route accepts XML and parses it with entity expansion enabled (noent: true). Parsed XML content and parser errors are returned in error messages, making local file disclosure via external entities plausible in production deployments where libxml entity resolution is available."
              },
              "help": {
                "text": "Remediation: Disable external entity and DTD processing, avoid returning parsed content/errors to clients, use a hardened XML parser with strict size/depth limits, and require authentication if uploads are business-only."
              },
              "properties": {
                "tags": [
                  "security",
                  "triage:confirmed",
                  "type:SAST",
                  "severity:high",
                  "CWE-611",
                  "CWE-200",
                  "A05:2021-Security Misconfiguration",
                  "A03:2021-Injection"
                ],
                "cwe": [
                  "CWE-611",
                  "CWE-200"
                ],
                "owasp": [
                  "A05:2021-Security Misconfiguration",
                  "A03:2021-Injection"
                ],
                "security-severity": "8.1",
                "precision": "high"
              }
            },
            {
              "id": "CANON-SAST-008",
              "name": "CANON-SAST-008",
              "shortDescription": {
                "text": "ZIP upload path traversal writes outside complaint upload directory"
              },
              "fullDescription": {
                "text": "ZIP entry names are attacker-controlled. The containment check only verifies that the resolved path contains the repository root, not that it remains below uploads/complaints, so entries such as ../../ftp/legal.md can overwrite other application files under the process working tree."
              },
              "help": {
                "text": "Remediation: Resolve the destination under a fixed base directory and require dest.startsWith(base + path.sep), reject absolute paths/symlinks/.. segments, generate server-side filenames, and scan archives before extraction."
              },
              "properties": {
                "tags": [
                  "security",
                  "triage:confirmed",
                  "type:SAST",
                  "severity:high",
                  "CWE-22",
                  "CWE-73",
                  "A01:2021-Broken Access Control",
                  "A05:2021-Security Misconfiguration"
                ],
                "cwe": [
                  "CWE-22",
                  "CWE-73"
                ],
                "owasp": [
                  "A01:2021-Broken Access Control",
                  "A05:2021-Security Misconfiguration"
                ],
                "security-severity": "7.8",
                "precision": "high"
              }
            },
            {
              "id": "CANON-SAST-009",
              "name": "CANON-SAST-009",
              "shortDescription": {
                "text": "Wallet balance can be inflated by client-supplied amount"
              },
              "fullDescription": {
                "text": "An authenticated user only needs an owned card record; the server then trusts req.body.balance and directly increments wallet funds. No payment processor confirmation, amount bounds, currency validation, or idempotency is enforced."
              },
              "help": {
                "text": "Remediation: Create server-side top-up intents, verify settled payment events from a payment provider, enforce positive bounded amounts, use idempotency keys, and store immutable ledger entries instead of direct balance mutation."
              },
              "properties": {
                "tags": [
                  "security",
                  "triage:confirmed",
                  "type:SAST",
                  "severity:high",
                  "CWE-840",
