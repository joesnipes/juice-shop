                "security-severity": "8.0",
                "precision": "high"
              }
            },
            {
              "id": "CANON-SAST-010",
              "name": "CANON-SAST-010",
              "shortDescription": {
                "text": "Sensitive operational directories are publicly browsable"
              },
              "fullDescription": {
                "text": "Anonymous clients can browse/download FTP files, encryption key files, logs, and metrics. In production this exposes order PDFs, operational logs, public keys/key metadata, endpoint inventory, and potentially tokens/PII in logs."
              },
              "help": {
                "text": "Remediation: Remove public directory indexing, move generated/sensitive files outside the web root, gate support logs and metrics behind admin auth and network allowlists, and redact logs."
              },
              "properties": {
