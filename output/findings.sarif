            {
              "id": "CANON-SAST-013",
              "name": "CANON-SAST-013",
              "shortDescription": {
                "text": "Generated user registration can set privileged role"
              },
              "fullDescription": {
                "text": "The public user creation flow is handled by a generated Finale resource, and the User model accepts role values including admin/accounting. The route middleware trims email/password but does not remove role from attacker-supplied request bodies, enabling mass-assignment privilege escalation."
              },
              "help": {
                "text": "Remediation: Use an explicit registration DTO/allowlist that only accepts email/password/security fields, force role server-side to customer, and separate admin user management behind privileged endpoints."
              },
              "properties": {
                "tags": [
                  "security",
                  "triage:confirmed",
                  "type:SAST",
                  "severity:critical",
